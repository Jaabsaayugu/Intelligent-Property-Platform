DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intelligent_property_platform
JWT_SECRET=replace-with-a-long-random-secret

# Render provides PORT automatically. Locally the API falls back to 5000.
PORT=5000

# Comma-separated frontend origins allowed to call this API from a browser.
CORS_ORIGIN=http://localhost:3000,https://afrealtydatahomes.vercel.app
