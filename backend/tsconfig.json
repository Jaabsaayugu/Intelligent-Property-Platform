{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@prisma/client": ["node_modules/.prisma/client"]
    },
    "types": ["node"]
  },
  "include": ["src", "ai_module", "prisma.config.ts"],
  "exclude": ["node_modules"]
}
