# Local development can omit these; the app falls back to http://localhost:5000/api.
# Set these on Vercel/production so the frontend calls the Render backend.
NEXT_PUBLIC_API_URL=https://intelligent-property-platform.onrender.com/api

# Server-side Next route handlers may use this origin-style URL.
API_URL=https://intelligent-property-platform.onrender.com
